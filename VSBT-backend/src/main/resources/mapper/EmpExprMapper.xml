<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vsbt.vsbtbackend.mapper.EmpExprMapper">

<!--批量保留员工工作经历-->
    <insert id="insertExprList">
        INSERT INTO emp_expr (emp_id, company, job, begin, end)
        VALUES
        <foreach collection="exprList" item="expr" separator=",">
            (#{expr.empId}, #{expr.company}, #{expr.job}, #{expr.begin}, #{expr.end})
        </foreach>
    </insert>
    <delete id="deleteByEmpIds">
        delete from emp_expr where emp_id in
        <foreach collection="empIds" item="empId" open="(" close=")" separator=",">
            #{empId}
        </foreach>
    </delete>
</mapper>